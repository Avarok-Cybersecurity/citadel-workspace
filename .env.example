# Internal service WebSocket port
INTERNAL_SERVICE_PORT=12345

# Workspace master password - used for first-time workspace initialization.
# Generate a strong random password for production and REPLACE the whole
# value below:
#   openssl rand -hex 32
# The placeholder is the single inert token `__CHANGE_ME__` (no trailing
# prose to accidentally leave behind as the password). Both deploy.sh and
# the server reject any value still containing `__CHANGE_ME__`, so an
# unmodified .env fails loudly instead of shipping a guessable default.
WORKSPACE_MASTER_PASSWORD=__CHANGE_ME__

# WebSocket URL the production UI build embeds at compile time. Vite
# substitutes `import.meta.env.VITE_WS_URL` during `npm run build`, so
# this MUST be set BEFORE `docker compose -f docker-compose.production.yml
# build ui`. Leave empty for local dev (frontend falls back to
# `ws://localhost:12345`); for production behind Cloudflare tunnel, set
# to the same-origin path the tunnel routes to the internal service,
# e.g. `wss://yourdomain.com/ws`. The nginx CSP `connect-src 'self'`
# blocks any cross-origin WebSocket — the browser will refuse to
# connect if VITE_WS_URL points off-origin.
VITE_WS_URL=

# Cloudflare Tunnel token (production only, used with --profile tunnel)
# Create at: https://one.dash.cloudflare.com → Networks → Tunnels
# TUNNEL_TOKEN=your-tunnel-token-here
