# Citadel Workspace - Production Caddyfile
#
# Environment variables:
#   DOMAIN              - Your domain name (default: localhost for local testing)
#   INTERNAL_SERVICE_PORT - WebSocket port for internal service (default: 12345)
#
# Usage:
#   DOMAIN=workspace.example.com docker compose -f docker-compose.production.yml up
#
# When DOMAIN is a real domain, Caddy automatically provisions TLS via Let's Encrypt.
# When DOMAIN is "localhost", Caddy uses its internal CA (self-signed).

{$DOMAIN:localhost} {
	# ---------------------------------------------------------------
	# WebSocket endpoint for the internal service
	# The frontend connects here for all real-time communication
	# ---------------------------------------------------------------
	handle /ws* {
		reverse_proxy internal-service:{$INTERNAL_SERVICE_PORT:12345} {
			# Flush immediately for WebSocket frames
			flush_interval -1
		}
	}

	# ---------------------------------------------------------------
	# UI - serve the React frontend (static files via nginx)
	# ---------------------------------------------------------------
	handle {
		reverse_proxy ui:80
	}

	# ---------------------------------------------------------------
	# Security headers
	# ---------------------------------------------------------------
	header {
		# Prevent MIME-type sniffing
		X-Content-Type-Options nosniff
		# Clickjacking protection
		X-Frame-Options DENY
		# XSS filter (legacy browsers)
		X-XSS-Protection "1; mode=block"
		# Referrer policy
		Referrer-Policy strict-origin-when-cross-origin
		# Remove server identification
		-Server
	}

	# ---------------------------------------------------------------
	# Logging
	# ---------------------------------------------------------------
	log {
		output stdout
		format json
		level INFO
	}
}
